# WalletConnect Cloud project ID (https://cloud.walletconnect.com)
# Optional for local dev — leave empty to use MetaMask / injected wallets only.
VITE_WALLETCONNECT_PROJECT_ID=

# Veil backend metadata API (see backend/)
VITE_API_URL=http://localhost:8787

# SIWE (must match backend SIWE_DOMAIN / SIWE_URI / CHAIN_ID)
VITE_SIWE_DOMAIN=localhost:5173
VITE_SIWE_URI=http://localhost:5173
VITE_SIWE_CHAIN_ID=11155111

# Sepolia JSON-RPC for wagmi (chain 11155111 — where Veil contracts live).
# VITE_SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# ETH/USD quote for converting decrypted owed amounts to Sepolia ETH at pay time.
# VITE_ETH_USD_PRICE=3000

# Deployed contract addresses (see contracts/)
VITE_GROUP_REGISTRY_ADDRESS=
VITE_CONFIDENTIAL_LEDGER_ADDRESS=
VITE_SETTLEMENTS_ADDRESS=
