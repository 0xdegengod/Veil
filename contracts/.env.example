# Sepolia deploy (copy to .env — never commit .env)
# Use the Zama FHEVM Sepolia RPC (standard Sepolia RPCs also work for broadcast;
# FHEVM RPC may print harmless forge receipt warnings — txs still land on-chain).
RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
PRIVATE_KEY=0xYOUR_DEPLOYER_PRIVATE_KEY

# Optional — verify on Etherscan after broadcast
# ETHERSCAN_API_KEY=

# Chain id for address extraction (default Sepolia)
CHAIN_ID=11155111
