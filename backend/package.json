{
  "name": "veil-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Off-chain metadata API for Veil (profiles, group index, invites, notifications). Stores NO plaintext amounts.",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:migrate:reminders": "tsx scripts/apply-sql-migration.ts drizzle/0001_expense_reminders_disputes.sql"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.38.3",
    "hono": "^4.6.14",
    "jose": "^6.2.3",
    "pg": "^8.13.1",
    "siwe": "^3.0.0",
    "viem": "^2.54.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.30.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
