# Postgres connection
# Local dev (docker compose up — uses override with published :5432):
DATABASE_URL=postgres://veil:veil@localhost:5432/veil
# Production (docker compose -f docker-compose.yml -f docker-compose.prod.yml):
# DATABASE_URL=postgres://veil:<POSTGRES_PASSWORD>@postgres:5432/veil
# POSTGRES_PASSWORD=change-me-to-a-strong-random-password

# HTTP server
PORT=8787

# Comma-separated allowed frontend origins (must match where the app is served)
# Local dev:
CORS_ORIGIN=http://localhost:5173
# Production example:
# CORS_ORIGIN=https://your-app.vercel.app

# SIWE + session (generate: openssl rand -base64 32)
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars
# Must match frontend VITE_SIWE_DOMAIN / VITE_SIWE_URI (hostname only for DOMAIN)
SIWE_DOMAIN=localhost:5173
SIWE_URI=http://localhost:5173
CHAIN_ID=11155111

# Sepolia RPC for verifying repayment transactions (optional — has a public default)
# SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Zama cUSDCMock wrapper for confidential cUSD repayment verification
# SEPOLIA_CONFIDENTIAL_USDC_ADDRESS=0x7c5BF43B851c1dff1a4feE8dB225b87f2C223639
